{
  "name": "mssgs",
  "displayName": "mssgs",
  "version": "0.1.0",
  "description": "Beeper-like unified messaging inside VSCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/marius-patrik/mssgs.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "mssgs.openMessenger",
        "title": "Open Messenger",
        "category": "mssgs"
      },
      {
        "command": "mssgs.addAccount",
        "title": "Add Account…",
        "category": "mssgs"
      },
      {
        "command": "mssgs.signOut",
        "title": "Sign Out",
        "category": "mssgs"
      },
      {
        "command": "mssgs.markAllAsRead",
        "title": "Mark All as Read",
        "category": "mssgs"
      },
      {
        "command": "mssgs.archiveConversation",
        "title": "Archive Conversation…",
        "category": "mssgs"
      },
      {
        "command": "mssgs.searchMessages",
        "title": "Search Messages…",
        "category": "mssgs"
      },
      {
        "command": "mssgs.focusSearch",
        "title": "Focus Search",
        "category": "mssgs"
      },
      {
        "command": "mssgs.newConversation",
        "title": "New Conversation",
        "category": "mssgs"
      },
      {
        "command": "mssgs.togglePinConversation",
        "title": "Toggle Pin Conversation",
        "category": "mssgs"
      },
      {
        "command": "mssgs.toggleFavoriteConversation",
        "title": "Toggle Favorite Conversation",
        "category": "mssgs"
      },
      {
        "command": "mssgs.archiveSelected",
        "title": "Archive Selected Conversation",
        "category": "mssgs"
      },
      {
        "command": "mssgs.setReminder",
        "title": "Set Reminder on Message…",
        "category": "mssgs"
      },
      {
        "command": "mssgs.scheduleMessage",
        "title": "Schedule Message…",
        "category": "mssgs"
      }
    ],
    "keybindings": [
      {
        "command": "mssgs.focusSearch",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s"
      },
      {
        "command": "mssgs.newConversation",
        "key": "ctrl+shift+alt+n",
        "mac": "cmd+shift+alt+n"
      },
      {
        "command": "mssgs.togglePinConversation",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p"
      },
      {
        "command": "mssgs.toggleFavoriteConversation",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f"
      },
      {
        "command": "mssgs.archiveSelected",
        "key": "ctrl+shift+alt+a",
        "mac": "cmd+shift+alt+a"
      },
      {
        "command": "mssgs.setReminder",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r"
      },
      {
        "command": "mssgs.scheduleMessage",
        "key": "ctrl+shift+alt+m",
        "mac": "cmd+shift+alt+m"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mssgs",
          "title": "mssgs",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "mssgs": [
        {
          "type": "webview",
          "id": "mssgs.messenger",
          "name": "Messenger"
        }
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "matrix-js-sdk": "^34.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  }
}
